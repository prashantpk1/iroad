		{
			"name": "Driver Profile",
			"item": [
				{
					"name": "Get Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "X-Tenant-ID",
								"value": "{{tenant_id}}"
							},
							{
								"key": "X-Language",
								"value": "en"
							}
						],
						"url": "{{base_url}}/api/v1/mobile/driver/profile/",
						"description": "Returns driver profile payload in `data` (shape from `DriverProfileSerializer`)."
					},
					"response": [
						{
							"name": "Profile fetch success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"Profile loaded successfully.\",\n  \"data\": {\n    \"driver\": {\n      \"driver_id\": \"uuid\",\n      \"driver_code\": \"DRV001\",\n      \"arabic_name\": null,\n      \"english_name\": \"John Driver\",\n      \"driver_status\": \"active\"\n    },\n    \"user\": {},\n    \"vehicle\": null,\n    \"attachments\": []\n  }\n}"
						},
						{
							"name": "Unauthorized (JWT)",
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 2,\n  \"message\": \"Unauthorized access. Please login to continue.\",\n  \"data\": {}\n}"
						}
					]
				},
				{
					"name": "Update Profile Photo",
