						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "X-Tenant-ID",
								"value": "{{tenant_id}}"
							},
							{
								"key": "X-Language",
								"value": "en"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "profile_photo",
									"description": "Image file: jpg, jpeg, png, webp — max 10 MB. Same endpoint supports PATCH.",
									"type": "file",
									"src": []
								}
							]
						},
						"url": "{{base_url}}/api/v1/mobile/driver/profile/photo/",
						"description": "Multipart field name must be **profile_photo**. Duplicate this request and set method to **PATCH** if you prefer PATCH (same body)."
					},
					"response": [
