							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"OTP has been sent if the email is registered.\",\n  \"data\": {}\n}"
						}
					]
				},
				{
