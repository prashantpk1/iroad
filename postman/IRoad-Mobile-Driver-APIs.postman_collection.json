						"description": "Verify reset-password OTP for the given email."
					},
					"response": [
						{
							"name": "OTP verified",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"OTP verified successfully.\",\n  \"data\": {}\n}"
						},
						{
							"name": "Invalid OTP",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 0,\n  \"message\": \"Incorrect OTP entered.\",\n  \"data\": {\n    \"attempts_remaining\": 2\n  }\n}"
						}
					]
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "X-Tenant-ID",
								"value": "{{tenant_id}}"
							},
							{
								"key": "X-Language",
								"value": "en"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"{{email}}\",\n  \"otp_code\": \"{{otp_code}}\",\n  \"new_password\": \"NewPassword@123\",\n  \"confirm_password\": \"NewPassword@123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{base_url}}/api/v1/mobile/driver/auth/reset-password/",
						"description": "Complete password reset after OTP verification."
					},
					"response": [
						{
							"name": "Password reset success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"Password reset successful.\",\n  \"data\": {}\n}"
						}
					]
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}"
							},
							{
								"key": "X-Tenant-ID",
								"value": "{{tenant_id}}"
							},
							{
								"key": "X-Language",
								"value": "en"
							}
						],
						"url": "{{base_url}}/api/v1/mobile/driver/auth/logout/",
						"description": "Invalidate current access token. No JSON body."
					},
					"response": [
						{
							"name": "Logout success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"Logout successful.\",\n  \"data\": {}\n}"
						},
						{
							"name": "Missing or invalid token",
							"status": "Unauthorized",
							"code": 401,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 0,\n  \"message\": \"Invalid authentication token. Please login again.\",\n  \"data\": {}\n}"
						}
					]
				}
			]
		},
		{
			"name": "Driver Change Password",
			"item": [
