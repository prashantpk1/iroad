							"name": "Photo updated",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 1,\n  \"message\": \"Profile photo updated successfully.\",\n  \"data\": {\n    \"profile_photo_url\": \"http://127.0.0.1:8000/media/drivers/photos/example.jpg\"\n  }\n}"
						},
						{
							"name": "Invalid image",
							"status": "Bad Request",
							"code": 400,
							"_postman_previewlanguage": "json",
							"header": [],
							"body": "{\n  \"status\": 0,\n  \"message\": \"Validation failed. Please check your input.\",\n  \"data\": {\n    \"errors\": {\n      \"profile_photo\": [\"The file must be a valid image (JPG, JPEG, PNG, or WEBP).\"]\n    }\n  }\n}"
						}
					]
				}
			]
